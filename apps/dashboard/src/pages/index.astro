---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatCard from "../components/StatCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import AgentCard from "../components/AgentCard.astro";
import TimelineItem from "../components/TimelineItem.astro";
import { tower, projectTimeline } from "../lib/tower-data";
import { SUMMARY_LABELS, UI } from "../lib/labels";
import { getProjectDisplay, getLocalizedEvent } from "../lib/localized-content";

const s = tower.summary;
const recent = tower.timeline.slice(0, 10);
const projects = tower.projects;
const agents = tower.agents;

// ACT-13D: per-project, the latest event's Chinese summary / next / phase
// are passed down so the ProjectCard can show them in Chinese while still
// falling back to the original English fields.
function latestEventZhFor(projectId: string) {
  const tl = projectTimeline(projectId);
  if (tl.length === 0) return null;
  // projectTimeline is in JSON-sorted (newest-first) order from the build.
  return getLocalizedEvent(tl[0]);
}
const projectsWithZh = projects.map((p) => ({
  project: p,
  display: getProjectDisplay(p),
  lastEventZh: latestEventZhFor(p.project_id),
}));

// Distinct values for filter dropdowns
const agentOptions = agents
  .map((a) => ({ id: a.agent_id, name: a.name }))
  .sort((a, b) => a.name.localeCompare(b.name));
---
<BaseLayout title="Agent Project Control Tower — 多 Agent 项目进度控制塔">
  <section>
    <h2>{UI.homeTitle}</h2>
    <div class="summary-grid">
      <StatCard label={SUMMARY_LABELS.PROJECTS} value={s.project_count} />
      <StatCard label={SUMMARY_LABELS.AGENTS}   value={s.agent_count} />
      <StatCard label={SUMMARY_LABELS.EVENTS}   value={s.event_count} />
      <StatCard label={SUMMARY_LABELS.GREEN}    value={s.green_count}   colorClass="green" />
      <StatCard label={SUMMARY_LABELS.YELLOW}   value={s.yellow_count}  colorClass="yellow" />
      <StatCard label={SUMMARY_LABELS.RED}      value={s.red_count}     colorClass="red" />
      <StatCard label={SUMMARY_LABELS.BLOCKED}  value={s.blocked_count} colorClass="red" />
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>{UI.projectsSection}</h2>
      <span class="count-badge" data-count-target>{projects.length} {UI.agentsTotal.toLowerCase()}</span>
    </div>
    <form class="filter-bar" data-filter-form aria-label="筛选项目"
      data-search-target="name,nameZh,id,repo,summary,summaryZh,last_agent">
      <label class="search-field">
        <span class="visually-hidden">搜索</span>
        <input
          type="search"
          name="q"
          placeholder={UI.projectsSearchPlaceholder}
          autocomplete="off"
        />
      </label>
      <label>
        <span class="visually-hidden">健康度</span>
        <select name="health">
          <option value="">{UI.projectsHealthAll}</option>
          <option value="green">green · 正常</option>
          <option value="yellow">yellow · 注意</option>
          <option value="red">red · 异常</option>
          <option value="gray">gray · 未知</option>
        </select>
      </label>
      <label>
        <span class="visually-hidden">状态</span>
        <select name="status">
          <option value="">{UI.projectsStatusAll}</option>
          <option value="ACTIVE">ACTIVE · 进行中</option>
          <option value="PASS">PASS · 通过</option>
          <option value="FAIL">FAIL · 失败</option>
          <option value="PARTIAL">PARTIAL · 部分完成</option>
          <option value="BLOCKED">BLOCKED · 阻塞</option>
          <option value="PAUSED">PAUSED · 暂停</option>
          <option value="RELEASED">RELEASED · 已发布</option>
        </select>
      </label>
      <label>
        <span class="visually-hidden">最近 Agent</span>
        <select name="last_agent">
          <option value="">{UI.projectsAgentsAll}</option>
          {agentOptions.map((a) => <option value={a.id}>{a.name}</option>)}
        </select>
      </label>
      <label>
        <span class="visually-hidden">排序</span>
        <select name="sort">
          <option value="updated">{UI.projectsSortUpdated}</option>
          <option value="health">{UI.projectsSortHealth}</option>
          <option value="name">{UI.projectsSortName}</option>
        </select>
      </label>
      <button type="button" data-filter-clear class="clear-btn">{UI.projectsClear}</button>
    </form>

    <div class="row-list" data-container="items">
      {projectsWithZh.map(({ project: p, display: d, lastEventZh: zh }) => (
        <div
          data-item="project"
          data-name={p.name}
          data-name-zh={d.nameZh && d.nameZh !== p.name ? d.nameZh : ""}
          data-id={p.project_id}
          data-repo={p.repo ?? ""}
          data-summary={p.last_summary ?? ""}
          data-summary-zh={zh?.summaryZh && zh.summaryZh !== p.last_summary ? zh.summaryZh : ""}
          data-health={p.current_health}
          data-status={p.current_status}
          data-last_agent={p.last_agent_id ?? ""}
          data-updated_at={p.last_event_at ?? ""}
        >
          <ProjectCard project={p} />
        </div>
      ))}
    </div>
    <p class="empty-state" data-empty-state hidden>
      {UI.projectsEmpty}
    </p>
  </section>

  <section>
    <div class="section-head">
      <h2>{UI.agentsSection}</h2>
      <span class="count-badge">{agents.length} {UI.agentsTotal}</span>
    </div>
    <div class="row-list">
      {agents.map((a) => <AgentCard agent={a} />)}
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>{UI.recentActivity}</h2>
      <span class="count-badge">{recent.length} {UI.recentShown}</span>
    </div>
    <div class="timeline">
      {recent.map((t) => <TimelineItem entry={t} />)}
    </div>
  </section>

  <script>
    import "../scripts/filters.ts";
  </script>
</BaseLayout>
