---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineItem from "../components/TimelineItem.astro";
import { tower } from "../lib/tower-data";
import { EVENT_TYPE_LABEL, UI } from "../lib/labels";
import { getLocalizedEvent, getProjectDisplay } from "../lib/localized-content";

// tower.timeline is already sorted newest-first by build_index.py.
const tl = tower.timeline;
const projectOptions = tower.projects
  .map((p) => {
    const d = getProjectDisplay(p);
    return { id: p.project_id, name: p.name, nameZh: d.nameZh };
  })
  .sort((a, b) => a.name.localeCompare(b.name));
const agentOptions = tower.agents
  .map((a) => ({ id: a.agent_id, name: a.name }))
  .sort((a, b) => a.name.localeCompare(b.name));

const eventTypes = Array.from(new Set(tl.map((t) => t.event_type))).sort();

// Pre-compute the Chinese view for each timeline entry so the
// data-* filter attributes can index both languages at once.
const tlWithZh = tl.map((t) => {
  const zh = getLocalizedEvent(t);
  return {
    entry: t,
    zh,
    nameForSearch: [
      t.event_type, t.phase_id ?? "", t.phase_name ?? "", t.summary ?? "",
      zh.phaseNameZh, zh.summaryZh,
    ].join(" "),
  };
});
---
<BaseLayout title="时间线 — Agent Project Control Tower">
  <section>
    <div class="section-head">
      <h2>{UI.timelineTitle}</h2>
      <span class="count-badge" data-count-target>{tl.length} {UI.timelineTotal}</span>
    </div>

    <form class="filter-bar" data-filter-form aria-label="筛选时间线"
      data-search-target="summary,summaryZh,phase_id,phase_name,phaseNameZh,event_type,project,agent">
      <label class="search-field">
        <span class="visually-hidden">搜索</span>
        <input
          type="search"
          name="q"
          placeholder={UI.timelineSearchPlaceholder}
          autocomplete="off"
        />
      </label>
      <label>
        <span class="visually-hidden">事件类型</span>
        <select name="event_type">
          <option value="">{UI.timelineEventTypeAll}</option>
          {eventTypes.map((et) => <option value={et}>{EVENT_TYPE_LABEL[et] ?? et}</option>)}
        </select>
      </label>
      <label>
        <span class="visually-hidden">状态</span>
        <select name="status">
          <option value="">{UI.timelineStatusAll}</option>
          <option value="ACTIVE">ACTIVE · 进行中</option>
          <option value="PASS">PASS · 通过</option>
          <option value="FAIL">FAIL · 失败</option>
          <option value="PARTIAL">PARTIAL · 部分完成</option>
          <option value="BLOCKED">BLOCKED · 阻塞</option>
          <option value="PAUSED">PAUSED · 暂停</option>
          <option value="RELEASED">RELEASED · 已发布</option>
        </select>
      </label>
      <label>
        <span class="visually-hidden">项目</span>
        <select name="project">
          <option value="">{UI.timelineProjectAll}</option>
          {projectOptions.map((p) => <option value={p.id}>{p.name}</option>)}
        </select>
      </label>
      <label>
        <span class="visually-hidden">Agent</span>
        <select name="agent">
          <option value="">{UI.timelineAgentAll}</option>
          {agentOptions.map((a) => <option value={a.id}>{a.name}</option>)}
        </select>
      </label>
      <label>
        <span class="visually-hidden">排序</span>
        <select name="sort">
          <option value="newest">{UI.timelineSortNewest}</option>
          <option value="oldest">{UI.timelineSortOldest}</option>
        </select>
      </label>
      <button type="button" data-filter-clear class="clear-btn">{UI.timelineClear}</button>
    </form>

    <div class="timeline" data-container="items">
      {tlWithZh.map(({ entry: t, zh, nameForSearch }) => (
        <div
          data-item="timeline"
          data-name={nameForSearch}
          data-summary={t.summary ?? ""}
          data-summary-zh={zh.summaryZh && zh.summaryZh !== t.summary ? zh.summaryZh : ""}
          data-phase_id={t.phase_id ?? ""}
          data-phase_name={t.phase_name ?? ""}
          data-phase_name-zh={zh.phaseNameZh && zh.phaseNameZh !== t.phase_name ? zh.phaseNameZh : ""}
          data-event_type={t.event_type}
          data-status={t.status}
          data-project={t.project_id ?? ""}
          data-agent={t.agent_id ?? ""}
          data-created_at={t.created_at}
        >
          <TimelineItem entry={t} />
        </div>
      ))}
    </div>
    <p class="empty-state" data-empty-state hidden>
      {UI.timelineEmpty}
    </p>
  </section>

  <script>
    import "../scripts/filters.ts";
  </script>
</BaseLayout>
