---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TimelineItem from "../../components/TimelineItem.astro";
import { tower, projectTimeline, groupByPhase } from "../../lib/tower-data";

// Pre-render one page per project. Astro requires this in getStaticPaths.
export function getStaticPaths() {
  return tower.projects.map((p) => ({
    params: { project_id: p.project_id },
  }));
}

const { project_id } = Astro.params;
const project = tower.projects.find((p) => p.project_id === project_id)!;
const timeline = projectTimeline(project_id);
const grouped = groupByPhase(timeline);

// Latest event is the first one (timeline is newest-first by build_index.py)
const latest = timeline[0] ?? null;
---
<BaseLayout title={`${project.name} — Agent Project Control Tower`}>
  <section>
    <div class="section-head">
      <h2>Project</h2>
      <span class={`pill pill-${project.current_health}`}>
        {project.current_health} · {project.current_status}
      </span>
    </div>
    <dl class="detail-grid">
      <dt>ID</dt>           <dd><code>{project.project_id}</code></dd>
      <dt>Name</dt>         <dd>{project.name}</dd>
      <dt>Repo</dt>         <dd>{project.repo ? <a href={project.repo}>{project.repo}</a> : "—"}</dd>
      <dt>Location</dt>     <dd>{project.location}</dd>
      <dt>Category</dt>     <dd>{project.category}</dd>
      <dt>Status</dt>       <dd><code>{project.current_status}</code></dd>
      <dt>Health</dt>       <dd><code>{project.current_health}</code></dd>
      <dt>Current phase</dt><dd>{project.current_phase_id ?? "—"} {project.current_phase_name && `· ${project.current_phase_name}`}</dd>
      <dt>Last agent</dt>   <dd>{project.last_agent_id ? <a href={`/agents/${project.last_agent_id}/`}>{project.last_agent_id}</a> : "—"}</dd>
      <dt>Last event at</dt><dd>{project.last_event_at ?? "—"}</dd>
      <dt>Event count</dt>  <dd>{project.event_count}</dd>
    </dl>
  </section>

  {latest && (
    <section>
      <h2>Latest event</h2>
      <div class="latest-card">
        <div class="latest-card-meta">
          <span class={`tl-type tl-type-${latest.event_type}`}>{latest.event_type}</span>
          <span>{latest.created_at}</span>
          {latest.agent_id && <span>· {latest.agent_id}</span>}
          {latest.phase_id && <span>· phase {latest.phase_id}</span>}
        </div>
        <div class="latest-card-summary">{latest.summary ?? "(no summary)"}</div>
      </div>
    </section>
  )}

  <section>
    <h2>Next actions</h2>
    {project.next
      ? <p class="next-block">{project.next}</p>
      : <p class="muted">No next action registered.</p>
    }
  </section>

  <section>
    <div class="section-head">
      <h2>Timeline (grouped by phase)</h2>
      <span class="count-badge">{timeline.length} events · {grouped.length} phases</span>
    </div>
    {timeline.length === 0
      ? <p class="muted">(no events yet)</p>
      : <div class="phase-groups">
          {grouped.map((g) => (
            <details open class="phase-group">
              <summary>
                <span class="phase-group-title">
                  {g.phase_id ?? "(no phase)"}{g.phase_name && ` — ${g.phase_name}`}
                </span>
                <span class="phase-group-count">{g.events.length}</span>
              </summary>
              <div class="timeline">
                {g.events.map((t) => <TimelineItem entry={t} />)}
              </div>
            </details>
          ))}
        </div>
    }
  </section>
</BaseLayout>
