---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TimelineItem from "../../components/TimelineItem.astro";
import {
  tower,
  agentTimeline,
  projectsByAgent,
  countByEventType,
} from "../../lib/tower-data";
import { EVENT_TYPE_LABEL, UI } from "../../lib/labels";
import { getProjectDisplay } from "../../lib/localized-content";

export function getStaticPaths() {
  return tower.agents.map((a) => ({
    params: { agent_id: a.agent_id },
  }));
}

const { agent_id } = Astro.params;
const agent = tower.agents.find((a) => a.agent_id === agent_id)!;
const timeline = agentTimeline(agent_id);
const projects = projectsByAgent(agent_id);
const typeCounts = countByEventType(timeline);

// ACT-13D: per-project Chinese display name for the "参与项目" list.
const projectsWithZh = projects.map((p) => {
  const d = getProjectDisplay(p);
  return {
    project: p,
    nameZh: d.nameZh && d.nameZh !== p.name ? d.nameZh : null,
  };
});

// Map event_type → badge CSS class (used for color-coded badges).
const TYPE_BADGE: Record<string, string> = {
  PHASE_REPORT:  "badge-phase",
  REVIEW_REPORT: "badge-review",
  HANDOFF:       "badge-handoff",
  RELEASE:       "badge-release",
  FAILURE:       "badge-failure",
  BLOCK:         "badge-block",
  UNBLOCK:       "badge-unblock",
  ARCHIVE:       "badge-archive",
  AGENT_REGISTERED:   "badge-info",
  PROJECT_REGISTERED: "badge-info",
};
---
<BaseLayout title={`${agent.name} — Agent Project Control Tower`}>
  <section>
    <div class="section-head">
      <h2>{UI.agentHeading}</h2>
      <span class="pill pill-gray">{agent.machine}</span>
    </div>
    <dl class="detail-grid">
      <dt>{UI.agentFieldId}</dt>             <dd><code>{agent.agent_id}</code></dd>
      <dt>{UI.agentFieldName}</dt>           <dd>{agent.name}</dd>
      <dt>{UI.agentFieldMachine}</dt>        <dd><code>{agent.machine}</code></dd>
      <dt>{UI.agentFieldRole}</dt>           <dd>{agent.role}</dd>
      <dt>{UI.agentFieldLastEventAt}</dt>    <dd>{agent.last_event_at ?? "—"}</dd>
      <dt>{UI.agentFieldLastProject}</dt>    <dd>{agent.last_project_id ? <a href={`/projects/${agent.last_project_id}/`}>{agent.last_project_id}</a> : "—"}</dd>
      <dt>{UI.agentFieldEventCount}</dt>     <dd>{agent.event_count}</dd>
    </dl>
  </section>

  <section>
    <h2>{UI.agentEventBreakdown}</h2>
    {timeline.length === 0
      ? <p class="muted">{UI.agentNoEvents}</p>
      : <div class="type-badges">
          {Object.entries(typeCounts).map(([k, n]) => (
            <span class={`type-badge ${TYPE_BADGE[k] ?? ""}`}>
              {EVENT_TYPE_LABEL[k] ?? k} · {n}
            </span>
          ))}
        </div>
    }
  </section>

  <section>
    <div class="section-head">
      <h2>{UI.agentProjectsTouchedTpl(projects.length)}</h2>
    </div>
    {projects.length === 0
      ? <p class="muted">{UI.agentNoProjects}</p>
      : <ul class="related-projects">
          {projectsWithZh.map(({ project: p, nameZh }) => (
            <li>
              <a href={`/projects/${p.project_id}/`}>
                {nameZh ? nameZh : p.name}
              </a>
              {nameZh && <span class="orig-suffix">（{p.name}）</span>}
              <span class={`pill pill-${p.current_health}`}>{p.current_health}</span>
            </li>
          ))}
        </ul>
    }
  </section>

  <section>
    <div class="section-head">
      <h2>{UI.agentActivityTimeline}</h2>
      <span class="count-badge">{UI.agentEventsTpl(timeline.length)}</span>
    </div>
    {timeline.length === 0
      ? <p class="muted">{UI.agentNoEvents}</p>
      : <div class="timeline">
          {timeline.map((t) => (
            <div
              data-item="agent-event"
              data-event_type={t.event_type}
              data-status={t.status}
            >
              <TimelineItem entry={t} />
            </div>
          ))}
        </div>
    }
  </section>
</BaseLayout>
