---
// AgentCard.astro — ACT-13B 中文化。
import type { Agent } from "../lib/tower-data";

interface Props {
  agent: Agent;
}
const { agent: a } = Astro.props;
---
<div class="row gray">
  <div class="head">
    <span class="title">
      <a href={`/agents/${a.agent_id}/`}>{a.name}</a>
    </span>
    <span class="tl-type">{a.machine}</span>
  </div>
  <div class="meta-line">
    角色: {a.role} ·
    最近项目: {a.last_project_id ?? "—"} ·
    事件: {a.event_count}
    {a.last_event_at && ` · ${a.last_event_at}`}
  </div>
</div>
